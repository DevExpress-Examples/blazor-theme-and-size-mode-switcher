@inject DxThemesService ThemesService
@rendermode InteractiveServer

<a class="themeswitcher-item list-group-item list-group-item-action @(ThemesService.ActiveTheme == Theme ? "active" : "text-body") @Theme.Name.ToLower()"
   @onclick:preventDefault
   @onclick="Anchor_Click">
    <span>@Theme.Title</span>
</a>
@code {
    [Parameter] public Theme Theme { get; set; }
    [Parameter] public EventCallback<Theme> Click { get; set; }

    async Task Anchor_Click() {
        await Click.InvokeAsync(Theme);
    }
}
