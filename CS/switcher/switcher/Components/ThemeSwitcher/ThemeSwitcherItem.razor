@inject DxThemesService ThemesService
@rendermode InteractiveServer

<li class="themeswitcher-color @Theme.Name @(ThemesService.ActiveTheme == Theme ? "active" : null)" style="--themeswitcher-color: @Theme.MenuBackgroundColor">
    <a
        @onclick:preventDefault
        @onclick="Anchor_Click">@Theme.Title</a>
</li>

@code {
    [Parameter] public Theme Theme { get; set; }
    [Parameter] public EventCallback<Theme> Click { get; set; }

    async Task Anchor_Click() {
        await Click.InvokeAsync(Theme);
    }
}
